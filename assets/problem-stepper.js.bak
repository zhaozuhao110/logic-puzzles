/**
 * 题目页“步骤推进器”
 * - 约定 DOM 结构：
 *   - .step-card：每个步骤卡片（带 data-step="1..n" 可选）
 *   - #btnPrev / #btnNext：上一/下一步按钮
 *   - #stepStatus：状态文本
 * - 交互行为：
 *   - 默认仅展示第 1 步；点击下一步逐步 reveal；点击卡片可直接跳转并高亮
 */
(function(){
  /**
   * 更新“步骤 x / y”状态文字，并保证读屏可感知
   * @param {HTMLElement} stepStatusEl 状态元素
   * @param {number} currentIndex 当前步骤（0-based）
   * @param {number} total 总步骤数
   */
  function updateStatus(stepStatusEl, currentIndex, total){
    stepStatusEl.textContent = '步骤 ' + (currentIndex + 1) + ' / ' + total;
  }

  /**
   * 将步骤卡片变为可键盘触达的控件（div 也能像按钮一样使用）
   * @param {HTMLElement} el 步骤卡元素
   * @param {number} index 序号（0-based）
   * @param {number} total 总数
   */
  function ensureStepCardA11y(el, index, total){
    if(!el) return;
    if(!el.hasAttribute('tabindex')) el.setAttribute('tabindex', '0');
    if(!el.hasAttribute('role')) el.setAttribute('role', 'button');
    if(!el.hasAttribute('aria-label')) el.setAttribute('aria-label', '第 ' + (index + 1) + ' 步（共 ' + total + ' 步）');
  }

  /**
   * 尝试从 hash / sessionStorage 读取初始步骤
   * - 支持：#step-3（从 1 开始）
   * @param {number} total 总步骤数
   * @returns {number} 初始 index（0-based）
   */
  function getInitialIndex(total){
    var hash = String(location.hash || '');
    var m = hash.match(/step-(\d+)/i);
    if(m){
      var idx = parseInt(m[1], 10) - 1;
      if(!isNaN(idx) && idx >= 0 && idx < total) return idx;
    }
    try{
      var key = 'problemStepper:last:' + location.pathname;
      var saved = sessionStorage.getItem(key);
      var savedIdx = saved == null ? NaN : parseInt(saved, 10);
      if(!isNaN(savedIdx) && savedIdx >= 0 && savedIdx < total) return savedIdx;
    }catch(e){}
    return 0;
  }

  /**
   * 记录当前步骤到 URL hash 与 sessionStorage
   * @param {number} currentIndex 当前步骤（0-based）
   */
  function persistIndex(currentIndex){
    try{
      history.replaceState(null, '', '#step-' + (currentIndex + 1));
    }catch(e){
      // 某些环境下 history API 不可用，忽略即可
    }
    try{
      var key = 'problemStepper:last:' + location.pathname;
      sessionStorage.setItem(key, String(currentIndex));
    }catch(e){}
  }

  /**
   * 切换当前步骤：高亮 + reveal + aria 状态
   * @param {Object} state 内部状态
   * @param {number} nextIndex 下一步（0-based）
   * @param {boolean} moveFocus 是否把焦点移动到当前步骤卡
   */
  function setActiveStep(state, nextIndex, moveFocus){
    if(nextIndex < 0 || nextIndex >= state.stepCards.length) return;
    state.currentIndex = nextIndex;
    if(state.currentIndex > state.maxVisible) state.maxVisible = state.currentIndex;

    for(var i=0;i<state.stepCards.length;i++){
      var el = state.stepCards[i];
      if(i <= state.maxVisible) el.classList.add('visible'); else el.classList.remove('visible');
      if(i === state.currentIndex) el.classList.add('active'); else el.classList.remove('active');

      // 读屏可感知：当前步骤
      if(i === state.currentIndex){
        el.setAttribute('aria-current', 'step');
        el.setAttribute('aria-pressed', 'true');
        el.setAttribute('aria-hidden', 'false');
      }else{
        el.removeAttribute('aria-current');
        el.setAttribute('aria-pressed', 'false');
        // 未 reveal 的步骤对读屏隐藏
        el.setAttribute('aria-hidden', i <= state.maxVisible ? 'false' : 'true');
      }
    }

    // 更新圆点指示器
    updateDots(state);

    state.btnPrev.disabled = state.currentIndex === 0;
    state.btnNext.disabled = state.currentIndex === state.stepCards.length - 1;
    updateStatus(state.stepStatus, state.currentIndex, state.stepCards.length);
    persistIndex(state.currentIndex);

    if(moveFocus){
      try{ state.stepCards[state.currentIndex].focus(); }catch(e){}
    }
  }

  function updateDots(state){
    if(!state.dots) return;
    for(var i=0;i<state.dots.length;i++){
      var dot = state.dots[i];
      var step = parseInt(dot.getAttribute('data-step'), 10) - 1;
      if(step === state.currentIndex){
        dot.classList.add('active');
        dot.setAttribute('aria-selected', 'true');
      }else{
        dot.classList.remove('active');
        dot.setAttribute('aria-selected', 'false');
      }
    }
  }

  function toggleShowAll(state){
    var stepsEl = document.getElementById('steps');
    var btnAll = state.btnAll;
    if(!stepsEl || !btnAll) return;

    state.showAll = !state.showAll;
    if(state.showAll){
      stepsEl.classList.add('show-all');
      btnAll.classList.add('active');
      btnAll.textContent = '收起';
      // 显示所有卡片
      for(var i=0;i<state.stepCards.length;i++){
        state.stepCards[i].classList.add('visible');
        state.stepCards[i].classList.remove('active');
        state.stepCards[i].setAttribute('aria-hidden', 'false');
      }
    }else{
      stepsEl.classList.remove('show-all');
      btnAll.classList.remove('active');
      btnAll.textContent = '全部';
      setActiveStep(state, 0, false);
    }
  }

  /**
   * 初始化步骤推进器（对外暴露）
   * - 补齐键盘可达：Tab/Enter/Space/方向键
   * - 补齐 aria：aria-current/aria-pressed/aria-hidden
   */
  function initProblemStepper(){
    // 防止重复绑定（例如页面脚本与自动初始化同时触发）
    if(window.__problemStepperInited) return;

    var stepCards = Array.prototype.slice.call(document.querySelectorAll('.step-card'));
    var btnPrev = document.getElementById('btnPrev');
    var btnNext = document.getElementById('btnNext');
    var stepStatus = document.getElementById('stepStatus');
    var btnAll = document.getElementById('btnAll');
    var dots = document.querySelectorAll('.step-dots .dot');

    if(!stepCards.length || !btnPrev || !btnNext || !stepStatus) return;

    // 读屏可感知的状态区
    stepStatus.setAttribute('role', 'status');
    stepStatus.setAttribute('aria-live', 'polite');

    // 按钮可读文案（避免只靠图标）
    if(!btnPrev.getAttribute('aria-label')) btnPrev.setAttribute('aria-label', '上一步');
    if(!btnNext.getAttribute('aria-label')) btnNext.setAttribute('aria-label', '下一步');
    if(btnAll && !btnAll.getAttribute('aria-label')) btnAll.setAttribute('aria-label', '显示全部步骤');

    var state = { stepCards: stepCards, btnPrev: btnPrev, btnNext: btnNext, btnAll: btnAll, dots: dots, stepStatus: stepStatus, currentIndex: 0, maxVisible: 0, showAll: false };

    // 初始化可访问性属性
    for(var k=0;k<stepCards.length;k++){
      ensureStepCardA11y(stepCards[k], k, stepCards.length);
    }

    btnPrev.addEventListener('click', function(){ setActiveStep(state, state.currentIndex - 1, true); });
    btnNext.addEventListener('click', function(){ setActiveStep(state, state.currentIndex + 1, true); });
    if(btnAll) btnAll.addEventListener('click', function(){ toggleShowAll(state); });

    // 圆点点击切换
    for(var di=0;di<dots.length;di++){
      (function(dotIdx){
        dots[dotIdx].addEventListener('click', function(){
          var targetStep = parseInt(dots[dotIdx].getAttribute('data-step'), 10) - 1;
          setActiveStep(state, targetStep, true);
        });
      })(di);
    }

    // 上一/下一步键盘支持（左右键）
    function bindNavKey(el, dir){
      el.addEventListener('keydown', function(e){
        var key = e.key;
        if(key === 'ArrowLeft' || key === 'ArrowUp'){
          e.preventDefault();
          setActiveStep(state, state.currentIndex - 1, true);
        }else if(key === 'ArrowRight' || key === 'ArrowDown'){
          e.preventDefault();
          setActiveStep(state, state.currentIndex + 1, true);
        }else if(key === 'Home'){
          e.preventDefault();
          setActiveStep(state, 0, true);
        }else if(key === 'End'){
          e.preventDefault();
          setActiveStep(state, state.stepCards.length - 1, true);
        }
      });
    }
    bindNavKey(btnPrev, -1);
    bindNavKey(btnNext, 1);

    for(var i=0;i<stepCards.length;i++){
      (function(idx){
        stepCards[idx].addEventListener('click', function(){ setActiveStep(state, idx, false); });
        stepCards[idx].addEventListener('keydown', function(e){
          var key = e.key;
          if(key === 'Enter' || key === ' '){
            e.preventDefault();
            setActiveStep(state, idx, false);
            return;
          }
          if(key === 'ArrowLeft' || key === 'ArrowUp'){
            e.preventDefault();
            setActiveStep(state, state.currentIndex - 1, true);
            return;
          }
          if(key === 'ArrowRight' || key === 'ArrowDown'){
            e.preventDefault();
            setActiveStep(state, state.currentIndex + 1, true);
            return;
          }
          if(key === 'Home'){
            e.preventDefault();
            setActiveStep(state, 0, true);
            return;
          }
          if(key === 'End'){
            e.preventDefault();
            setActiveStep(state, state.stepCards.length - 1, true);
            return;
          }
        });
      })(i);
    }

    setActiveStep(state, getInitialIndex(stepCards.length), false);

    window.__problemStepperInited = true;
  }

  window.initProblemStepper = initProblemStepper;

  /**
   * 自动初始化（解决：script 使用 defer 时，页面底部直接调用 initProblemStepper 可能早于脚本加载的问题）。
   */
  (function autoInit(){
    function run(){
      try{ initProblemStepper(); }catch(e){}
    }
    if(document.readyState === 'loading'){
      document.addEventListener('DOMContentLoaded', run);
    }else{
      run();
    }
  })();
})();
