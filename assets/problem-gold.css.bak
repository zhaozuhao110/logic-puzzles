/* =========================================================
 * 题目页统一样式（深色金色强调）
 * - 搭配 base.css + theme.js 使用
 * - 允许各题目页用内联 style 仅覆盖 :root 变量或局部细节
 * ========================================================= */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --gold-bg:#0f0d0a;--gold-surface:#1a1712;--gold-card:#241f18;
  --gold-bright:#f0c94d;--gold-mid:#d4a537;--gold-dim:#8a6d1b;
  --cream:#e8dcc8;--cream-dim:#9e9483;--border:rgba(212,165,55,0.15);
}
[data-theme="light"]{
  --gold-bg:#fdfaf0;--gold-surface:#ffffff;--gold-card:#ffffff;
  --gold-bright:#d4a537;--gold-mid:#b08235;--gold-dim:#85672a;
  --cream:#1a1410;--cream-dim:#5a5550;--border:rgba(176,130,53,0.2);
}
body{
  font-family:'Noto Serif SC',serif;background:var(--gold-bg);color:var(--cream);
  min-height:100vh;overflow-x:hidden;line-height:1.8;
}
.bg{
  position:fixed;inset:0;z-index:0;pointer-events:none;
  background:
    radial-gradient(ellipse 60% 50% at 50% 10%,var(--page-glow-1, rgba(212,165,55,0.05)),transparent),
    radial-gradient(ellipse 50% 45% at 18% 86%,var(--page-glow-2, rgba(74,122,223,0.04)),transparent),
    var(--gold-bg);
}
.bg::before{
  content:'';position:absolute;inset:0;
  /* 可变背景纹理（由 assets/theme.js 根据题目自动设置变量） */
  background:var(--page-pattern,
    linear-gradient(135deg,transparent 45%,var(--border) 49%,var(--gold-dim) 50%,var(--border) 51%,transparent 55%),
    linear-gradient(45deg,transparent 45%,var(--border) 49%,var(--gold-dim) 50%,var(--border) 51%,transparent 55%)
  );
  background-size:var(--page-pattern-size, 60px 60px);
  background-position:var(--page-pattern-pos, center);
  opacity:var(--page-pattern-opacity, 0.10);
}
.bg::after{
  content:'';position:absolute;inset:0;
  background:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.6' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  opacity:0.05;mix-blend-mode:color-dodge;
}
.container{position:relative;z-index:2;max-width:900px;margin:0 auto;padding:0 24px}
.hero{
  position:relative;
  min-height:80vh;display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:40px 0;
}
.hero::after{
  content:'';
  position:absolute;
  width:var(--hero-mark-size, 420px);
  height:var(--hero-mark-size, 420px);
  right:clamp(-120px, -10vw, -40px);
  top:clamp(40px, 10vh, 120px);
  background-image:var(--hero-mark, none);
  background-repeat:no-repeat;
  background-size:contain;
  background-position:center;
  opacity:var(--hero-mark-opacity, 0.09);
  filter:blur(0.2px) saturate(1.1);
  pointer-events:none;
  z-index:0;
  transform:rotate(var(--hero-mark-rotate, -6deg));
}
[data-theme="light"] .hero::after{
  opacity:var(--hero-mark-opacity-light, 0.08);
}
.hero-icon{width:64px;height:64px;margin-bottom:20px;color:var(--gold-mid);opacity:0.85}
.hero h1{
  font-family:'Playfair Display','Noto Serif SC',serif;
  font-size:clamp(2rem,5.5vw,3.4rem);font-weight:900;
  background:linear-gradient(135deg,var(--gold-bright),var(--gold-mid),var(--gold-dim));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  letter-spacing:0.04em;line-height:1.2;margin-bottom:10px;
}
.subtitle{
  font-size:clamp(0.9rem,2vw,1.1rem);color:var(--cream-dim);font-weight:300;
  letter-spacing:0.22em;margin-bottom:34px;text-transform:uppercase;
}
.hero-question{
  max-width:640px;text-align:left;background:var(--gold-card);border:1px solid var(--border);
  padding:22px 26px;border-radius:10px;font-size:0.95rem;color:var(--cream-dim);line-height:2;
  box-shadow:0 10px 30px rgba(0,0,0,0.12);
}
.hero-question strong{color:var(--gold-mid);font-weight:650}
.story-hook{
  margin:0 0 12px;
  padding:10px 12px;
  border-radius:10px;
  border:1px solid rgba(212,165,55,0.14);
  background:rgba(212,165,55,0.06);
  color:var(--cream-dim);
  font-size:0.9rem;
  line-height:1.9;
}
[data-theme="light"] .story-hook{background:rgba(176,130,53,0.06)}
/* 段落节奏对齐：参考 three-bulbs.html */
section{padding:var(--space-9, 54px) 0}
.label{display:inline-block;font-size:0.72rem;letter-spacing:0.28em;color:var(--gold-dim);margin-bottom:10px;text-transform:uppercase}
.heading{font-size:clamp(1.45rem,3vw,2rem);color:var(--cream);font-weight:800;margin-bottom:18px;line-height:1.35}
.card{background:var(--gold-surface);border:1px solid var(--border);border-radius:12px;padding:28px}
.nav{display:flex;align-items:center;justify-content:space-between;gap:12px;margin:14px 0 18px}
.nav .status{font-size:0.85rem;color:var(--cream-dim);letter-spacing:0.08em}
.btn{
  appearance:none;border:1px solid var(--border);background:transparent;color:var(--cream-dim);
  padding:10px 14px;border-radius:10px;cursor:pointer;font-family:'Noto Serif SC',serif;
  font-size:0.9rem;transition:all .25s;
}
.btn:hover{border-color:rgba(212,165,55,0.35);color:var(--gold-bright);transform:translateY(-1px)}
.btn:disabled{opacity:.35;cursor:not-allowed;transform:none}
.steps{display:flex;flex-direction:column;gap:12px}
.step-card{
  display:none;background:rgba(0,0,0,0.14);border:1px solid rgba(212,165,55,0.10);
  border-radius:12px;padding:18px 18px 16px;transition:all .25s;
}
[data-theme="light"] .step-card{background:rgba(176,130,53,0.06)}
.step-card.visible{display:block}
.step-card.active{border-color:rgba(212,165,55,0.45);box-shadow:0 0 0 4px rgba(212,165,55,0.06)}
.step-title{display:flex;align-items:center;gap:10px;margin-bottom:6px}
.badge{
  width:24px;height:24px;border-radius:999px;background:linear-gradient(135deg,var(--gold-bright),var(--gold-mid));
  color:var(--gold-bg);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:0.78rem;flex:0 0 auto;
}
.step-card h3{font-size:1rem;color:var(--gold-mid);font-weight:800}
.step-card p{font-size:0.92rem;color:var(--cream-dim);line-height:1.9}
.insight{margin-top:22px}
.insight ul{margin:10px 0 0 18px;color:var(--cream-dim);font-size:0.92rem;line-height:1.9}
.insight li strong{color:var(--gold-mid)}
.note{margin-top:12px;color:var(--cream-dim);font-size:0.9rem}

/* ===== 步骤进度指示器 ===== */
.step-dots{
  display:flex;gap:8px;align-items:center;
}
.dot{
  width:10px;height:10px;border-radius:50%;
  border:1px solid rgba(212,165,55,0.3);
  background:transparent;cursor:pointer;
  transition:all .25s;padding:0;
}
.dot.active{
  background:var(--gold-mid);
  border-color:var(--gold-mid);
  transform:scale(1.15);
}
.dot:hover:not(.active){
  border-color:var(--gold-bright);
}

/* ===== 数学公式高亮 ===== */
.formula{
  display:inline-block;
  font-family:'Playfair Display',serif;
  font-size:1.1em;
  font-weight:700;
  color:var(--gold-bright);
  background:rgba(212,165,55,0.1);
  padding:2px 10px;
  border-radius:6px;
  border:1px solid rgba(212,165,55,0.2);
  letter-spacing:0.03em;
}
.formula-inline{
  font-family:'Playfair Display',serif;
  font-weight:600;
  color:var(--gold-bright);
}

/* ===== 答案卡片 ===== */
.answer-card{
  display:flex;align-items:flex-start;gap:14px;
  margin-top:18px;padding:18px;
  background:linear-gradient(135deg,rgba(212,165,55,0.12),rgba(212,165,55,0.04));
  border:1px solid rgba(212,165,55,0.25);
  border-radius:12px;
}
.answer-icon{
  width:36px;height:36px;border-radius:50%;
  background:linear-gradient(135deg,var(--gold-bright),var(--gold-mid));
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.answer-icon svg{width:20px;height:20px;stroke:var(--gold-bg);stroke-width:2.5}
.answer-text strong{
  display:block;
  font-size:1.05rem;
  color:var(--cream);
  margin-bottom:4px;
}
.answer-text p{color:var(--cream-dim);font-size:0.92rem;margin:0}
.highlight{
  font-weight:700;
  color:var(--gold-bright);
  font-size:1.15em;
}

/* ===== 洞见图标 ===== */
.insight-icon{
  color:var(--gold-mid);
  margin-right:6px;
  font-style:normal;
}

/* ===== 步骤动画 ===== */
@keyframes fadeSlideIn{
  from{opacity:0;transform:translateY(12px)}
  to{opacity:1;transform:translateY(0)}
}
.step-card{
  display:none;background:rgba(0,0,0,0.14);border:1px solid rgba(212,165,55,0.10);
  border-radius:12px;padding:18px 18px 16px;transition:all .25s;
  animation:fadeSlideIn .35s ease-out;
}
.step-card.visible{display:block}

/* ===== 全部展开模式 ===== */
.steps.show-all .step-card{
  display:block;
  margin-bottom:14px;
}
.steps.show-all .step-card:last-child{margin-bottom:0}

/* ===== 面包屑 / 标签（可选） ===== */
.breadcrumb{
  display:flex;align-items:center;gap:10px;
  padding-top:22px;margin-bottom:10px;
  color:var(--cream-dim);font-size:0.85rem;letter-spacing:0.08em;
}
.breadcrumb-link{
  color:var(--cream-dim);text-decoration:none;
  padding:6px 10px;border-radius:999px;
  border:1px solid rgba(212,165,55,0.18);
  background:rgba(212,165,55,0.06);
  transition:all .25s;
}
.breadcrumb-link:hover{border-color:rgba(212,165,55,0.35);color:var(--gold-bright)}
.breadcrumb-sep{opacity:0.6}
.breadcrumb-current{color:var(--cream)}

.meta-row{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin:10px 0 18px}
.meta-chip{
  display:inline-flex;align-items:center;
  padding:7px 12px;border-radius:999px;
  border:1px solid rgba(212,165,55,0.18);
  background:rgba(212,165,55,0.06);
  color:var(--cream-dim);font-size:0.82rem;letter-spacing:0.06em;
}
[data-theme="light"] .meta-chip{background:rgba(176,130,53,0.06)}

/* ===== 结论块 / 延伸块（可选） ===== */
.conclusion{
  border-radius:16px;
  border:1px solid rgba(212,165,55,0.16);
  background:rgba(212,165,55,0.04);
  padding:18px 18px;
}
[data-theme="light"] .conclusion{background:rgba(176,130,53,0.06)}
.conclusion strong{color:var(--gold-bright)}

/* ===== 前后篇 / 推荐（可选） ===== */
.subheading{margin:16px 0 12px;font-size:1.05rem;font-weight:800;color:var(--cream)}
.pager{display:grid;grid-template-columns:repeat(2, 1fr);gap:14px;margin-top:18px}
.pager-card{
  display:flex;flex-direction:column;gap:8px;
  text-decoration:none;color:inherit;
  padding:18px;border-radius:16px;
  border:1px solid rgba(212,165,55,0.16);
  background:rgba(212,165,55,0.03);
  transition:all .25s;
}
.pager-card:hover{transform:translateY(-2px);border-color:rgba(212,165,55,0.35);background:rgba(212,165,55,0.06)}
.pager-kicker{font-size:0.72rem;letter-spacing:0.18em;color:var(--cream-dim);text-transform:uppercase}
.pager-title{font-size:1.05rem;font-weight:900;color:var(--gold-bright);line-height:1.25}
.pager-desc{font-size:0.9rem;color:var(--cream-dim);line-height:1.7}

.reco{margin-top:18px}
.reco-grid{display:grid;grid-template-columns:repeat(3, 1fr);gap:14px}
.reco-card{
  display:flex;flex-direction:column;gap:8px;
  text-decoration:none;color:inherit;
  padding:18px;border-radius:16px;
  border:1px solid rgba(212,165,55,0.14);
  background:rgba(255,255,255,0.02);
  transition:all .25s;
}
.reco-card:hover{transform:translateY(-2px);border-color:rgba(212,165,55,0.35);background:rgba(212,165,55,0.05)}
.reco-title{font-weight:900;color:var(--cream);font-size:1rem}
.reco-desc{color:var(--cream-dim);font-size:0.9rem;line-height:1.7}

.more-actions{
  margin-top:18px;
  display:flex;
  gap:10px;
  flex-wrap:wrap;
}

@media (max-width:900px){.reco-grid{grid-template-columns:1fr}}
@media (max-width:700px){.pager{grid-template-columns:1fr}}
